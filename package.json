{
  "repository": {
    "type": "git",
    "url": "https://github.com/mhansen/hledger-vscode.git"
  },
  "name": "hledger-vscode",
  "displayName": "hledger-vscode",
  "description": "Language support for HLedger accounting journals.",
  "version": "0.0.12",
  "publisher": "mark-hansen",
  "engines": {
    "vscode": "^1.14.0"
  },
  "scripts": {
    "test": "mocha -r ts-node/register tests/test.ts",
    "goldens": "ts-node tests/main.ts"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:hledger"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "hledger",
        "aliases": [
          "HLedger",
          "hledger"
        ],
        "extensions": [
          ".hledger",
          ".journal",
          ".journal.txt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": [
      {
        "title": "Hledger",
        "properties": {
          "hledger.hledgerPath": {
            "type": "string",
            "default": "hledger"
          },
          "hledger.ledgerFile": {
            "type": "string",
            "description": "Default: $LEDGER_FILE or $HOME/.hledger.journal"
          }
        }
      }
    ],
    "grammars": [
      {
        "language": "hledger",
        "scopeName": "source.hledger",
        "path": "./syntaxes/hledger.tmLanguage.json"
      }
    ]
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.12.11",
    "minimist": "^1.2.8",
    "mocha": "^10.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.0.0"
  }
}
